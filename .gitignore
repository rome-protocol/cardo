# Burner devnet keypairs used by the bootstrap scripts.
# These are pre-funded and short-lived — never commit them.
scripts/keys/*.priv*

# Secret material — defense in depth. Treasury/relayer keys live OUTSIDE the
# repo (<your-secrets-dir>/…); these patterns ensure key material never lands here
# even by accident, and never trips GitHub secret scanning on push.
*.key
*.pem
*.p12
*.keypair
*-keypair.json
.secrets/
secrets/
